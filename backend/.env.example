# Copy to `.env` and fill in to enable real LLM answers.
# Without any key the AI chat runs in deterministic mock mode.
#
# Provider is auto-detected: if OPENAI_API_KEY is set it is used; otherwise
# ANTHROPIC_API_KEY; otherwise mock mode. (OpenAI wins if both are set.)

# --- OpenAI ---
# OPENAI_API_KEY=sk-proj-...
# AI_MODEL=gpt-4o-mini

# --- Anthropic (alternative) ---
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-6

# PORT=4000
# CORS_ORIGIN=http://localhost:5200
